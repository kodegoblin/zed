// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "auto_update": true,
  "relative_line_numbers": "enabled",
  "soft_wrap": "editor_width",
  "use_auto_surround": true,
  "use_autoclose": true,
  "document_folding_ranges": "off",
  "semantic_tokens": "combined",
  "document_symbols": "off",
  "icon_theme": {
    "mode": "light",
    "light": "Material Icon Theme",
    "dark": "Material Icon Theme"
  },
  "colorize_brackets": true,
  "collaboration_panel": {
    "default_width": 320.0,
  },
  "git_panel": {
    "default_width": 320.0,
  },
  "agent": {
    "default_width": 340.0,
  },
  "outline_panel": {
    "default_width": 320.0,
  },
  "cursor_blink": false,
  "git": {
    "hunk_style": "staged_hollow",
    "inline_blame": {
      "enabled": false,
    },
  },
  "project_panel": {
    "default_width": 320.0,
    "diagnostic_badges": true,
  },
  "tabs": {
    "show_diagnostics": "all",
  },
  "toolbar": {
    "breadcrumbs": false,
    "quick_actions": false,
    "selections_menu": false,
    "code_actions": false,
  },
  "hover_popover_hiding_delay": 400,
  "hover_popover_delay": 400,
  "show_signature_help_after_edits": false,
  "auto_signature_help": false,
  "use_smartcase_search": true,
  "close_on_file_delete": true,
  "file_finder": {
    "modal_max_width": null,
  },
  "preferred_line_length": 110,
  "scrollbar": {
    "show": "never",
  },
  "sticky_scroll": {
    "enabled": true,
  },
  "vertical_scroll_margin": 10.0,
  "terminal": {
    "scrollbar": {
      "show": "never",
    },
    "dock": "bottom",
    "default_height": 460,
  },
  "which_key": {
    "delay_ms": 0,
    "enabled": true,
  },
  "vim": {
    "cursor_shape": {
      "visual": "underline",
    },
    "gdefault": true,
    "use_smartcase_find": true,
    "use_system_clipboard": "on_yank",
    "toggle_relative_line_numbers": true,
  },
  "autosave": {
    "after_delay": {
      "milliseconds": 5000,
    },
  },
  "disable_ai": true,
  "cli_default_open_behavior": "new_window",
  "buffer_line_height": {
    "custom": 1.15,
  },
  "telemetry": {
    "diagnostics": true,
    "metrics": false,
  },
  "session": {
    "trust_all_worktrees": true,
  },
  "inlay_hints": {
    "show_background": false,
    "enabled": true,
  },
  "diagnostics": {
    "lsp_pull_diagnostics": {
      "debounce_ms": 150,
    },
    "inline": {
      "enabled": true,
    },
  },
  "helix_mode": false,
  "vim_mode": true,
  "base_keymap": "VSCode",
  "buffer_font_weight": 500.0,
  "ui_font_weight": 500.0,
  "buffer_font_family": "CaskaydiaCove Nerd Font",
  "ui_font_size": 15.0,
  "buffer_font_size": 14.0,
  "theme": {
    "mode": "system",
    "light": "One Light",
    "dark": "Sonokai Custom"
  },
  "gutter": {
    "min_line_number_digits": 0,
    "runnables": true,
    "folds": true,
    "breakpoints": true,
  },
  "show_wrap_guides": false,
  "wrap_guides": [110],

  // ===== Token based highlighting of syntax ================================================================
  "global_lsp_settings": {
    "semantic_token_rules": [
      {
        "token_type": "builtinType",
        "style": ["type.builtin"],
      },
      {
        "token_type": "macro",
        "style": ["function.special"],
      },
      {
        "token_type": "selfTypeKeyword",
        "style": ["type.builtin"],
      },
      {
        "token_type": "operator",
        "token_modifiers": ["controlFlow"],
        "style": ["keyword"],
      },
    ],
  },
}
